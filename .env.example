# --- AI Providers (Provide at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD=0.10
CLASSIFICATION_MODEL="openrouter/x-ai/grok-4.20-multi-agent"
SCORING_MODEL="openrouter/x-ai/grok-4.20-multi-agent"

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
